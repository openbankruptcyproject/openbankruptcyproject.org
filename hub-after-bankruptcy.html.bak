        .hub-toc li { margin-bottom: 6px; }
        .hub-toc a { font-size: 0.95rem; }

        .cta-box { background: linear-gradient(135deg, #161b22 0%, #1a2332 100%); border: 1px solid var(--green); border-radius: 10px; padding: 32px; margin: 40px 0; text-align: center; }
        .cta-box p { color: var(--text); font-size: 1.05rem; margin-bottom: 16px; }
        .cta-box a.btn { display: inline-block; background: var(--green); color: #fff; padding: 12px 28px; border-radius: 6px; font-weight: 600; font-size: 0.95rem; }
        .cta-box a.btn:hover { background: #2ea043; color: #fff; }

        .breadcrumb-nav{font-size:0.85rem;color:#8b949e;padding:0.5rem 0;max-width:900px;margin:0 auto}.breadcrumb-nav a{color:#58a6ff;text-decoration:none}.breadcrumb-nav a:hover{text-decoration:underline}.breadcrumb-nav .separator{margin:0 0.5rem;color:#484f58}

        footer {
