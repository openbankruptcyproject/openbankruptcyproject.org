        .resource-card h3 a { color: var(--text); }
        .resource-card h3 a:hover { color: var(--accent); }
        .resource-card .domain { font-size: 0.85rem; color: var(--accent); margin-bottom: 8px; }
        .resource-card p { color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 0; line-height: 1.7; }

        .hub-toc { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 24px; margin-bottom: 32px; }
        .hub-toc h2 { margin-top: 0; font-size: 1.1rem; margin-bottom: 12px; }
