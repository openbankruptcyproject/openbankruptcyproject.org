.84" r="3" fill="#58a6ff"><title>FY2020: 14,128 filings</title></circle><circle cx="484.50" cy="102.32" r="3" fill="#58a6ff"><title>FY2021: 8,341 filings</title></circle><circle cx="526.00" cy="92.27" r="3" fill="#58a6ff"><title>FY2022: 10,028 filings</title></circle><circle cx="567.50" cy="88.39" r="3" fill="#58a6ff"><title>FY2023: 10,678 filings</title></circle><circle cx="609.00" cy="95.12" r="3" fill="#58a6ff"><title>FY2024: 9,549 filings</title></circle><circle cx="650.50" cy="102.33" r="3" fill="#58a6ff"><title>FY2025: 8,338 filings</title></circle><circle cx="692.00" cy="143.83" r="3" fill="#7d8590"><title>FY2026: 1,372 filings (incomplete - current FY)</title></circle><text x="28.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2010</text><text x="111.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2012</text><text x="194.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2014</text><text x="277.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2016</text><text x="360.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2018</text><text x="443.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2020</text><text x="526.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2022</text><text x="609.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2024</text><text x="692.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2026</text><text x="22" y="32.0" fill="#7d8590" font-size="11" text-anchor="end">20,817</text><text x="22" y="156.0" fill="#7d8590" font-size="11" text-anchor="end">0</text></svg></div>
</section>
<section id="chapter-mix">
<h2><span class="label">Section 02</span>Chapter Mix</h2>
<p>Distribution of cases filed in S.D. Miss. by bankruptcy chapter. Computed over the 311,540 cases with a non-blank chapter code in the FJC IDB.</p>
<div class="card"><svg class="chart chart-chapter-mix" role="img" aria-label="Chapter mix: Chapter 13 69.0%, Chapter 7 30.4%, Chapter 11 0.6%, Chapter 12 0.1%, Chapter 15 0.0%, Chapter 9 0.0%" viewBox="0 0 720 48" preserveAspectRatio="none" width="100%" height="48"><g><title>Chapter 13: 214,891 cases (69.0%)</title><rect x="0.00" y="0" width="496.66" height="48" fill="#3fb950" /><text x="248.33" y="29.0" fill="#0d1117" text-anchor="middle" font-size="14" font-weight="700">Ch 13 69.0%</text></g><g><title>Chapter 7: 94,565 cases (30.4%)</title><rect x="496.66" y="0" width="218.52" height="48" fill="#58a6ff" /><text x="605.92" y="29.0" fill="#0d1117" text-anchor="middle" font-size="14" font-weight="700">Ch 7 30.4%</text></g><g><title>Chapter 11: 1,870 cases (0.6%)</title><rect x="715.18" y="0" width="4.32" height="48" fill="#d29922" /></g><g><title>Chapter 12: 184 cases (0.1%)</title><rect x="719.50" y="0" width="0.43" height="48" fill="#a371f7" /></g><g><title>Chapter 15: 18 cases (0.0%)</title><rect x="719.93" y="0" width="0.07" height="48" fill="#7d8590" /></g><g><title>Chapter 9: 12 cases (0.0%)</title><rect x="720.00" y="0" width="0.00" height="48" fill="#f85149" /></g></svg><div class="chart-legend"><span class="legend-item"><i class="swatch" style="background:#3fb950"></i>Chapter 13 - Wage-earner plan (69.0%, 214,891 cases)</span> <span class="legend-item"><i class="swatch" style="background:#58a6ff"></i>Chapter 7 - Liquidation (30.4%, 94,565 cases)</span> <span class="legend-item"><i class="swatch" style="background:#d29922"></i>Chapter 11 - Reorganization (0.6%, 1,870 cases)</span> <span class="legend-item"><i class="swatch" style="background:#a371f7"></i>Chapter 12 - Family farmer / fisherman (0.1%, 184 cases)</span> <span class="legend-item"><i class="swatch" style="background:#7d8590"></i>Chapter 15 - Cross-border / ancillary (0.0%, 18 cases)</span> <span class="legend-item"><i class="swatch" style="background:#f85149"></i>Chapter 9 - Municipality (0.0%, 12 cases)</span></div>
<table class="table" aria-label="Chapter mix table">
<thead><tr><th>Chapter</th><th>Purpose</th><th>Cases</th><th>Share</th></tr></thead>
<tbody><tr><td>Chapter 13</td><td>Wage-earner plan</td><td class="num">214,891</td><td class="num">68.98%</td></tr><tr><td>Chapter 7</td><td>Liquidation</td><td class="num">94,565</td><td class="num">30.35%</td></tr><tr><td>Chapter 11</td><td>Reorganization</td><td class="num">1,870</td><td class="num">0.6%</td></tr><tr><td>Chapter 12</td><td>Family farmer / fisherman</td><td class="num">184</td><td class="num">0.06%</td></tr><tr><td>Chapter 15</td><td>Cross-border / ancillary</td><td class="num">18</td><td class="num">0.01%</td></tr><tr><td>Chapter 9</td><td>Municipality</td><td class="num">12</td><td class="num">0.0%</td></tr></tbody></table>
</div>
</section>
<section id="dispositions">
<h2><span class="label">Section 03</span>Case Dispositions</h2>
<p>Of cases filed in S.D. Miss. from FY 2005 onward, 115,996 have a terminal disposition recorded in the FJC Integrated Database (37.9% of 305,969 in-window cases). 189,973 remain unclassified - either still open at the last FJC extract or not yet coded.</p>
<div class="callout">Percentages reflect cases with a terminal disposition coded in the FJC Integrated Database. Blank dispositions (cases still open, or outcomes not yet coded at the last FJC extract) are counted separately in &quot;unclassified&quot; and excluded from the percentage denominator. This is typical of IDB coverage; see the methodology page for detail.</div>
