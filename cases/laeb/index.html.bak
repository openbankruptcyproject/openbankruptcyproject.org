48" r="3" fill="#58a6ff"><title>FY2020: 7,928 filings</title></circle><circle cx="484.50" cy="107.77" r="3" fill="#58a6ff"><title>FY2021: 4,835 filings</title></circle><circle cx="526.00" cy="112.29" r="3" fill="#58a6ff"><title>FY2022: 4,341 filings</title></circle><circle cx="567.50" cy="95.12" r="3" fill="#58a6ff"><title>FY2023: 6,218 filings</title></circle><circle cx="609.00" cy="97.54" r="3" fill="#58a6ff"><title>FY2024: 5,953 filings</title></circle><circle cx="650.50" cy="104.06" r="3" fill="#58a6ff"><title>FY2025: 5,240 filings</title></circle><circle cx="692.00" cy="143.71" r="3" fill="#7d8590"><title>FY2026: 906 filings (incomplete - current FY)</title></circle><text x="28.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2010</text><text x="111.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2012</text><text x="194.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2014</text><text x="277.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2016</text><text x="360.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2018</text><text x="443.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2020</text><text x="526.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2022</text><text x="609.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2024</text><text x="692.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2026</text><text x="22" y="32.0" fill="#7d8590" font-size="11" text-anchor="end">13,555</text><text x="22" y="156.0" fill="#7d8590" font-size="11" text-anchor="end">0</text></svg></div>
</section>
<section id="chapter-mix">
<h2><span class="label">Section 02</span>Chapter Mix</h2>
<p>Distribution of cases filed in E.D. La. by bankruptcy chapter. Computed over the 178,422 cases with a non-blank chapter code in the FJC IDB.</p>
<div class="card"><svg class="chart chart-chapter-mix" role="img" aria-label="Chapter mix: Chapter 13 71.6%, Chapter 7 27.1%, Chapter 11 1.3%, Chapter 12 0.0%, Chapter 15 0.0%" viewBox="0 0 720 48" preserveAspectRatio="none" width="100%" height="48"><g><title>Chapter 13: 127,673 cases (71.6%)</title><rect x="0.00" y="0" width="515.23" height="48" fill="#3fb950" /><text x="257.62" y="29.0" fill="#0d1117" text-anchor="middle" font-size="14" font-weight="700">Ch 13 71.6%</text></g><g><title>Chapter 7: 48,333 cases (27.1%)</title><rect x="515.23" y="0" width="195.05" height="48" fill="#58a6ff" /><text x="612.76" y="29.0" fill="#0d1117" text-anchor="middle" font-size="14" font-weight="700">Ch 7 27.1%</text></g><g><title>Chapter 11: 2,368 cases (1.3%)</title><rect x="710.28" y="0" width="9.58" height="48" fill="#d29922" /></g><g><title>Chapter 12: 42 cases (0.0%)</title><rect x="719.86" y="0" width="0.14" height="48" fill="#a371f7" /></g><g><title>Chapter 15: 6 cases (0.0%)</title><rect x="720.00" y="0" width="0.00" height="48" fill="#7d8590" /></g></svg><div class="chart-legend"><span class="legend-item"><i class="swatch" style="background:#3fb950"></i>Chapter 13 - Wage-earner plan (71.6%, 127,673 cases)</span> <span class="legend-item"><i class="swatch" style="background:#58a6ff"></i>Chapter 7 - Liquidation (27.1%, 48,333 cases)</span> <span class="legend-item"><i class="swatch" style="background:#d29922"></i>Chapter 11 - Reorganization (1.3%, 2,368 cases)</span> <span class="legend-item"><i class="swatch" style="background:#a371f7"></i>Chapter 12 - Family farmer / fisherman (0.0%, 42 cases)</span> <span class="legend-item"><i class="swatch" style="background:#7d8590"></i>Chapter 15 - Cross-border / ancillary (0.0%, 6 cases)</span></div>
<table class="table" aria-label="Chapter mix table">
<thead><tr><th>Chapter</th><th>Purpose</th><th>Cases</th><th>Share</th></tr></thead>
<tbody><tr><td>Chapter 13</td><td>Wage-earner plan</td><td class="num">127,673</td><td class="num">71.56%</td></tr><tr><td>Chapter 7</td><td>Liquidation</td><td class="num">48,333</td><td class="num">27.09%</td></tr><tr><td>Chapter 11</td><td>Reorganization</td><td class="num">2,368</td><td class="num">1.33%</td></tr><tr><td>Chapter 12</td><td>Family farmer / fisherman</td><td class="num">42</td><td class="num">0.02%</td></tr><tr><td>Chapter 15</td><td>Cross-border / ancillary</td><td class="num">6</td><td class="num">0.0%</td></tr></tbody></table>
</div>
</section>
<section id="dispositions">
<h2><span class="label">Section 03</span>Case Dispositions</h2>
<p>Of cases filed in E.D. La. from FY 2005 onward, 57,471 have a terminal disposition recorded in the FJC Integrated Database (32.6% of 176,152 in-window cases). 118,681 remain unclassified - either still open at the last FJC extract or not yet coded.</p>
<div class="callout">Percentages reflect cases with a terminal disposition coded in the FJC Integrated Database. Blank dispositions (cases still open, or outcomes not yet coded at the last FJC extract) are counted separately in &quot;unclassified&quot; and excluded from the percentage denominator. This is typical of IDB coverage; see the methodology page for detail.</div>
