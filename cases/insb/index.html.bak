    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root { --bg:#0d1117; --surface:#151b23; --border:#252d38; --text:#e6edf3; --text-secondary:#b1bac4; --text-muted:#7d8590; --accent:#58a6ff; --green:#3fb950; --gold:#d29922; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: var(--text); line-height: 1.7; }
        a { color: var(--accent); text-decoration: none; }
        a:hover { text-decoration: underline; }
        .container { max-width: 1040px; margin: 0 auto; padding: 0 32px; }
        nav.topnav { border-bottom: 1px solid var(--border); padding: 18px 0; position: sticky; top: 0; background: rgba(13,17,23,0.95); backdrop-filter: blur(12px); z-index: 100; }
        nav.topnav .container { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
        .nav-brand { font-size: 1.05rem; font-weight: 700; color: var(--text); }
        .nav-links { display: flex; gap: 24px; flex-wrap: wrap; }
        .nav-links a { color: var(--text-muted); font-size: 0.88rem; font-weight: 500; }
        .nav-links a.active { color: var(--text); }
        .breadcrumb { padding: 16px 0; font-size: 0.85rem; color: var(--text-muted); }
        .breadcrumb a { color: var(--text-muted); }
        .breadcrumb .sep { margin: 0 8px; color: var(--border); }
        .hero { padding: 48px 0 32px; border-bottom: 1px solid var(--border); }
        .hero .label { font-size: 0.78rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 10px; }
        .hero h1 { font-size: 2rem; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 14px; line-height: 1.2; }
        .hero p { color: var(--text-secondary); font-size: 1rem; max-width: 760px; }
        .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin: 32px 0; }
        .stat-cell { background: var(--surface); padding: 28px 16px; text-align: center; }
        .stat-number { font-size: 1.75rem; font-weight: 800; display: block; letter-spacing: -0.02em; margin-bottom: 4px; }
        .stat-number.accent { color: var(--accent); }
        .stat-number.green { color: var(--green); }
        .stat-number.gold { color: var(--gold); }
        .stat-label { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; font-weight: 500; }
        .section { padding: 40px 0; border-bottom: 1px solid var(--border); }
        .section h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: 12px; }
        .section p { color: var(--text-secondary); margin-bottom: 16px; }
        .page-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 10px; margin-top: 20px; }
        .page-list a { background: var(--surface); border: 1px solid var(--border); padding: 14px 16px; border-radius: 8px; font-size: 0.9rem; font-weight: 500; text-align: center; }
        .page-list a:hover { background: rgba(88,166,255,0.1); text-decoration: none; }
        .page-list a.active { background: var(--accent); color: #fff; border-color: var(--accent); }
        .chapter-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin-top: 20px; }
        .chapter-stat { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 22px 20px; text-align: center; }
        .chapter-stat .ch-num { display: block; font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; margin-bottom: 8px; }
        .chapter-stat .ch-count { display: block; font-size: 1.5rem; font-weight: 800; color: var(--accent); letter-spacing: -0.02em; margin-bottom: 4px; }
        .chapter-stat .ch-pct { display: block; font-size: 0.82rem; color: var(--text-muted); margin-bottom: 10px; }
        .chapter-stat .ch-bar-track { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
        .chapter-stat .ch-bar-fill { height: 100%; background: var(--accent); border-radius: 2px; }
        .year-bars { display: flex; gap: 10px; align-items: flex-end; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 24px 20px 14px; margin-top: 20px; overflow-x: auto; }
        .yr-bar-wrap { flex: 1 1 0; min-width: 42px; display: flex; flex-direction: column; align-items: center; }
        .yr-bar { width: 100%; max-width: 34px; background: linear-gradient(180deg, var(--accent), #1f6feb); border-radius: 3px 3px 0 0; min-height: 6px; }
        .yr-label { display: block; font-size: 0.72rem; color: var(--text-muted); margin-top: 6px; font-weight: 600; }
        .yr-count { display: block; font-size: 0.68rem; color: var(--text-muted); margin-top: 2px; }
        .recent-table { width: 100%; border-collapse: collapse; background: var(--surface); border: 1px solid var(--border); border-radius: 10px; overflow: hidden; margin-top: 20px; }
        .recent-table th { background: var(--bg); text-align: left; padding: 12px 16px; font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 600; border-bottom: 1px solid var(--border); }
        .recent-table td { padding: 12px 16px; font-size: 0.88rem; border-bottom: 1px solid var(--border); }
        .recent-table tr:last-child td { border-bottom: none; }
        .attribution { padding: 20px 24px; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; font-size: 0.85rem; color: var(--text-muted); margin: 32px 0; }
        .attribution strong { color: var(--text-secondary); }
        .attribution a { color: var(--text-secondary); }
        footer { padding: 40px 0; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 0.85rem; text-align: center; }
        footer a { color: var(--text-muted); margin: 0 10px; }
    </style>
</head>
