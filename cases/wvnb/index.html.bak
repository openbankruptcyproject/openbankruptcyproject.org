<style>*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0d1117;--surface:#151b23;--surface-hover:#1a2230;--border:#252d38;--border-light:#2d3748;--text:#e6edf3;--text-secondary:#b1bac4;--text-muted:#7d8590;--accent:#58a6ff;--accent-hover:#79b8ff;--green:#3fb950;--amber:#d29922;--rose:#f85149}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;background:var(--bg);color:var(--text);line-height:1.7;-webkit-font-smoothing:antialiased}
a{color:var(--accent);text-decoration:none}a:hover{color:var(--accent-hover);text-decoration:underline}
.container{max-width:1040px;margin:0 auto;padding:0 32px}
nav.topnav{border-bottom:1px solid var(--border);padding:18px 0;position:sticky;top:0;background:rgba(13,17,23,.95);backdrop-filter:blur(12px);z-index:100}
nav.topnav .container{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.nav-brand{font-size:1.05rem;font-weight:700;color:var(--text)}
.nav-links{display:flex;gap:24px;flex-wrap:wrap}
.nav-links a{color:var(--text-muted);font-size:.88rem;font-weight:500}
.nav-links a:hover,.nav-links a.active{color:var(--text);text-decoration:none}
.breadcrumb{padding:16px 0;font-size:.85rem;color:var(--text-muted)}
.breadcrumb a{color:var(--text-muted)}.breadcrumb a:hover{color:var(--accent)}
.breadcrumb .sep{margin:0 8px;color:var(--border-light)}
.hero{padding:40px 0 28px;border-bottom:1px solid var(--border)}
.hero .label{font-size:.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:8px}
.hero h1{font-size:2.2rem;font-weight:800;letter-spacing:-.025em;margin-bottom:12px;line-height:1.15}
.hero .subtitle{color:var(--text-secondary);font-size:1.02rem;max-width:760px;margin-bottom:6px}
.hero .datastamp{color:var(--text-muted);font-size:.85rem;margin-top:12px}
.hero .datastamp a{color:var(--text-muted);text-decoration:underline}
main{padding:32px 0 72px}
h2{margin:40px 0 14px;font-size:1.35rem;font-weight:700;letter-spacing:-.01em}
h2 .label{display:block;font-size:.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:4px}
h3{margin:22px 0 10px;font-size:1.05rem;font-weight:700;color:var(--text)}
p{margin-bottom:14px;color:var(--text-secondary)}
.stat-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:1px;background:var(--border);border:1px solid var(--border);border-radius:10px;overflow:hidden;margin:28px 0}
.stat-cell{background:var(--surface);padding:22px 20px;text-align:center}
.stat-cell .v{display:block;font-size:1.45rem;font-weight:800;color:var(--text);letter-spacing:-.02em;margin-bottom:4px;font-variant-numeric:tabular-nums}
.stat-cell .v.accent{color:var(--accent)}
.stat-cell .v.green{color:var(--green)}
.stat-cell .v.amber{color:var(--amber)}
.stat-cell .k{font-size:.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;font-weight:600;line-height:1.4}
.card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:24px 26px;margin:18px 0}
.card .note{color:var(--text-muted);font-size:.85rem;margin-top:10px}
.chart-legend{display:flex;flex-wrap:wrap;gap:12px 20px;margin-top:14px;font-size:.88rem;color:var(--text-secondary)}
.legend-item{display:inline-flex;align-items:center;gap:8px}
.swatch{display:inline-block;width:12px;height:12px;border-radius:3px}
.table{width:100%;border-collapse:collapse;margin:12px 0;font-size:.92rem}
.table th{background:var(--bg);text-align:left;padding:10px 12px;font-size:.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;font-weight:600;border-bottom:1px solid var(--border)}
.table td{padding:10px 12px;border-bottom:1px solid var(--border);color:var(--text-secondary)}
.table tr:last-child td{border-bottom:none}
.table td.num{text-align:right;font-variant-numeric:tabular-nums;color:var(--text)}
.rank-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:18px;margin:14px 0}
.rank-widget{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px 18px}
.rank-widget .rank-label{font-size:.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;font-weight:600;margin-bottom:6px}
.rank-widget .rank-annot{font-size:.88rem;color:var(--text-secondary);margin-top:4px}
.rank-widget .rank-pct{color:var(--accent)}
.peer-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;margin:14px 0}
.peer{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:16px 18px;transition:.15s}
.peer:hover{background:var(--surface-hover);border-color:var(--accent)}
.peer .label{font-size:.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;font-weight:600}
.peer h4{font-size:1rem;font-weight:700;margin:6px 0;color:var(--text)}
.peer .num{color:var(--text-secondary);font-size:.9rem;font-variant-numeric:tabular-nums}
.faq details{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px 20px;margin-bottom:10px}
.faq summary{cursor:pointer;font-weight:600;color:var(--text);list-style:none}
.faq summary::-webkit-details-marker{display:none}
.faq summary::after{content:'+';float:right;color:var(--text-muted);font-weight:300;font-size:1.4rem;line-height:1}
.faq details[open] summary::after{content:'−'}
.faq details[open] summary{margin-bottom:10px;color:var(--accent)}
.faq details p{margin:10px 0 0;color:var(--text-secondary)}
.callout{background:var(--surface);border-left:3px solid var(--amber);padding:14px 18px;margin:16px 0;border-radius:0 6px 6px 0;color:var(--text-secondary);font-size:.92rem}
.obp-footer{border-top:1px solid var(--border);margin-top:48px;padding-top:28px;color:var(--text-muted);font-size:.9rem}
.obp-footer__disclaimer{background:var(--surface);border-left:3px solid var(--accent);padding:14px 18px;border-radius:0 6px 6px 0;margin-bottom:22px;color:var(--text-secondary)}
.obp-footer__disclaimer strong{color:var(--text)}
.obp-footer__attribution p{margin-bottom:10px}
.obp-footer__stamp{color:var(--text-muted);font-size:.85rem;margin-top:14px}
footer.site-footer{padding:30px 0;border-top:1px solid var(--border);color:var(--text-muted);font-size:.85rem;text-align:center}
@media(max-width:720px){.hero h1{font-size:1.75rem}.stat-cell .v{font-size:1.2rem}}</style>
</head>
