14" r="3" fill="#58a6ff"><title>FY2020: 1,760 filings</title></circle><circle cx="484.50" cy="122.70" r="3" fill="#58a6ff"><title>FY2021: 1,262 filings</title></circle><circle cx="526.00" cy="127.55" r="3" fill="#58a6ff"><title>FY2022: 1,053 filings</title></circle><circle cx="567.50" cy="126.23" r="3" fill="#58a6ff"><title>FY2023: 1,110 filings</title></circle><circle cx="609.00" cy="126.14" r="3" fill="#58a6ff"><title>FY2024: 1,114 filings</title></circle><circle cx="650.50" cy="125.65" r="3" fill="#58a6ff"><title>FY2025: 1,135 filings</title></circle><circle cx="692.00" cy="147.01" r="3" fill="#7d8590"><title>FY2026: 215 filings (incomplete - current FY)</title></circle><text x="28.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2010</text><text x="111.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2012</text><text x="194.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2014</text><text x="277.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2016</text><text x="360.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2018</text><text x="443.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2020</text><text x="526.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2022</text><text x="609.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2024</text><text x="692.00" y="168" fill="#7d8590" font-size="11" text-anchor="middle">2026</text><text x="22" y="32.0" fill="#7d8590" font-size="11" text-anchor="end">5,341</text><text x="22" y="156.0" fill="#7d8590" font-size="11" text-anchor="end">0</text></svg></div>
</section>
<section id="chapter-mix">
<h2><span class="label">Section 02</span>Chapter Mix</h2>
<p>Distribution of cases filed in N.D.W. Va. by bankruptcy chapter. Computed over the 50,507 cases with a non-blank chapter code in the FJC IDB.</p>
<div class="card"><svg class="chart chart-chapter-mix" role="img" aria-label="Chapter mix: Chapter 7 65.1%, Chapter 13 33.7%, Chapter 11 1.2%, Chapter 12 0.0%" viewBox="0 0 720 48" preserveAspectRatio="none" width="100%" height="48"><g><title>Chapter 7: 32,860 cases (65.1%)</title><rect x="0.00" y="0" width="468.43" height="48" fill="#58a6ff" /><text x="234.22" y="29.0" fill="#0d1117" text-anchor="middle" font-size="14" font-weight="700">Ch 7 65.1%</text></g><g><title>Chapter 13: 17,037 cases (33.7%)</title><rect x="468.43" y="0" width="242.86" height="48" fill="#3fb950" /><text x="589.86" y="29.0" fill="#0d1117" text-anchor="middle" font-size="14" font-weight="700">Ch 13 33.7%</text></g><g><title>Chapter 11: 590 cases (1.2%)</title><rect x="711.29" y="0" width="8.42" height="48" fill="#d29922" /></g><g><title>Chapter 12: 20 cases (0.0%)</title><rect x="719.71" y="0" width="0.29" height="48" fill="#a371f7" /></g></svg><div class="chart-legend"><span class="legend-item"><i class="swatch" style="background:#58a6ff"></i>Chapter 7 - Liquidation (65.1%, 32,860 cases)</span> <span class="legend-item"><i class="swatch" style="background:#3fb950"></i>Chapter 13 - Wage-earner plan (33.7%, 17,037 cases)</span> <span class="legend-item"><i class="swatch" style="background:#d29922"></i>Chapter 11 - Reorganization (1.2%, 590 cases)</span> <span class="legend-item"><i class="swatch" style="background:#a371f7"></i>Chapter 12 - Family farmer / fisherman (0.0%, 20 cases)</span></div>
<table class="table" aria-label="Chapter mix table">
<thead><tr><th>Chapter</th><th>Purpose</th><th>Cases</th><th>Share</th></tr></thead>
<tbody><tr><td>Chapter 7</td><td>Liquidation</td><td class="num">32,860</td><td class="num">65.06%</td></tr><tr><td>Chapter 13</td><td>Wage-earner plan</td><td class="num">17,037</td><td class="num">33.73%</td></tr><tr><td>Chapter 11</td><td>Reorganization</td><td class="num">590</td><td class="num">1.17%</td></tr><tr><td>Chapter 12</td><td>Family farmer / fisherman</td><td class="num">20</td><td class="num">0.04%</td></tr></tbody></table>
</div>
</section>
<section id="dispositions">
<h2><span class="label">Section 03</span>Case Dispositions</h2>
<p>Of cases filed in N.D.W. Va. from FY 2005 onward, 26,332 have a terminal disposition recorded in the FJC Integrated Database (52.9% of 49,798 in-window cases). 23,466 remain unclassified - either still open at the last FJC extract or not yet coded.</p>
<div class="callout">Percentages reflect cases with a terminal disposition coded in the FJC Integrated Database. Blank dispositions (cases still open, or outcomes not yet coded at the last FJC extract) are counted separately in &quot;unclassified&quot; and excluded from the percentage denominator. This is typical of IDB coverage; see the methodology page for detail.</div>
