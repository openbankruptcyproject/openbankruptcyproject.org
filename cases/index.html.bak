<style>*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0d1117;--surface:#151b23;--surface-hover:#1a2230;--border:#252d38;--border-light:#2d3748;--text:#e6edf3;--text-secondary:#b1bac4;--text-muted:#7d8590;--accent:#58a6ff;--accent-hover:#79b8ff;--green:#3fb950;--amber:#d29922}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;background:var(--bg);color:var(--text);line-height:1.7;-webkit-font-smoothing:antialiased}
a{color:var(--accent);text-decoration:none}a:hover{color:var(--accent-hover);text-decoration:underline}
.container{max-width:1200px;margin:0 auto;padding:0 32px}
nav.topnav{border-bottom:1px solid var(--border);padding:18px 0;position:sticky;top:0;background:rgba(13,17,23,.95);backdrop-filter:blur(12px);z-index:100}
nav.topnav .container{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
.nav-brand{font-size:1.05rem;font-weight:700}
.nav-links{display:flex;gap:24px;flex-wrap:wrap}
.nav-links a{color:var(--text-muted);font-size:.88rem;font-weight:500}
.nav-links a:hover,.nav-links a.active{color:var(--text);text-decoration:none}
.breadcrumb{padding:16px 0;font-size:.85rem;color:var(--text-muted)}
.breadcrumb a{color:var(--text-muted)}.breadcrumb a:hover{color:var(--accent)}
.breadcrumb .sep{margin:0 8px;color:var(--border-light)}
.hero{padding:44px 0 28px;border-bottom:1px solid var(--border)}
.hero .label{font-size:.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:8px}
.hero h1{font-size:2.25rem;font-weight:800;letter-spacing:-.025em;margin-bottom:12px}
.hero p{color:var(--text-secondary);font-size:1rem;max-width:820px}
.stat-strip{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:1px;background:var(--border);border:1px solid var(--border);border-radius:10px;overflow:hidden;margin:32px 0}
.stat-cell{background:var(--surface);padding:20px 18px;text-align:center}
.stat-cell .v{display:block;font-size:1.5rem;font-weight:800;letter-spacing:-.02em;font-variant-numeric:tabular-nums}
.stat-cell .v.accent{color:var(--accent)}.stat-cell .v.green{color:var(--green)}
.stat-cell .k{font-size:.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;font-weight:600;margin-top:4px;line-height:1.4}
main{padding:32px 0 72px}
h2{margin:36px 0 12px;font-size:1.3rem;font-weight:700;letter-spacing:-.01em}
h3{margin:20px 0 6px;font-size:1rem;font-weight:700;color:var(--text-secondary)}
.circuit-section{margin:28px 0}
.circuit-section h3{display:flex;align-items:center;gap:12px}
.circuit-section h3::after{content:'';flex:1;height:1px;background:var(--border)}
.dist-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:10px;margin:14px 0}
.dist-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:12px 14px;transition:.15s;text-decoration:none}
.dist-card:hover{background:var(--surface-hover);border-color:var(--accent);transform:translateY(-1px);text-decoration:none}
.dist-card .label{font-size:.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;font-weight:600}
.dist-card h4{font-size:.98rem;font-weight:700;color:var(--text);margin:4px 0 6px}
.dist-card .meta{display:flex;gap:12px;font-size:.82rem;color:var(--text-muted);font-variant-numeric:tabular-nums}
.attribution{padding:20px 24px;background:var(--surface);border:1px solid var(--border);border-radius:8px;font-size:.88rem;color:var(--text-muted);margin:32px 0}
.attribution a{color:var(--text-secondary)}.attribution a:hover{color:var(--accent)}
footer{padding:36px 0;border-top:1px solid var(--border);color:var(--text-muted);font-size:.85rem;text-align:center}</style>
</head>
