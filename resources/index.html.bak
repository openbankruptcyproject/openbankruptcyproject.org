<style>*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0d1117;--surface:#151b23;--surface-hover:#1a2230;--border:#252d38;--border-light:#2d3748;--text:#e6edf3;--text-secondary:#b1bac4;--text-muted:#7d8590;--accent:#58a6ff;--accent-hover:#79b8ff;--green:#3fb950;--amber:#d29922}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Helvetica,Arial,sans-serif;background:var(--bg);color:var(--text);line-height:1.72;-webkit-font-smoothing:antialiased}
a{color:var(--accent);text-decoration:none}a:hover{color:var(--accent-hover);text-decoration:underline}
.container{max-width:880px;margin:0 auto;padding:0 32px}
nav.topnav{border-bottom:1px solid var(--border);padding:18px 0;position:sticky;top:0;background:rgba(13,17,23,.95);backdrop-filter:blur(12px);z-index:100}
nav.topnav .container{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;max-width:1200px}
.nav-brand{font-size:1.05rem;font-weight:700;color:var(--text)}
.nav-links{display:flex;gap:24px;flex-wrap:wrap}
.nav-links a{color:var(--text-muted);font-size:.88rem;font-weight:500}
.nav-links a:hover,.nav-links a.active{color:var(--text);text-decoration:none}
.breadcrumb{padding:16px 0;font-size:.85rem;color:var(--text-muted)}
.breadcrumb a{color:var(--text-muted)}.breadcrumb a:hover{color:var(--accent)}
.breadcrumb .sep{margin:0 8px;color:var(--border-light)}
.hero{padding:42px 0 24px;border-bottom:1px solid var(--border)}
.hero .label{font-size:.8rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.08em;font-weight:600;margin-bottom:10px}
.hero h1{font-size:2.2rem;font-weight:800;letter-spacing:-.025em;margin-bottom:14px;line-height:1.18}
.hero p.lede{color:var(--text-secondary);font-size:1.02rem;max-width:760px}
.hero .datastamp{color:var(--text-muted);font-size:.85rem;margin-top:16px}
main{padding:28px 0 56px}
main h2{font-size:1.35rem;font-weight:700;margin:36px 0 12px;letter-spacing:-.01em}
main h3{font-size:1.05rem;font-weight:700;margin:22px 0 8px;color:var(--text)}
main p{color:var(--text-secondary);margin-bottom:14px}
main ul,main ol{margin:10px 0 18px 22px;color:var(--text-secondary)}
main li{margin-bottom:6px}
main strong{color:var(--text)}
main code{background:var(--surface);padding:2px 6px;border-radius:4px;font-size:.88em;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace}
.callout{background:var(--surface);border-left:3px solid var(--accent);padding:14px 20px;margin:18px 0;border-radius:0 6px 6px 0;font-size:.95rem}
.callout strong{color:var(--text)}
.card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:22px 24px;margin:18px 0}
.card h3{margin-top:0}
.link-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin:14px 0}
.link-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px 16px;transition:.15s}
.link-card:hover{background:var(--surface-hover);border-color:var(--accent)}
.link-card .label{font-size:.72rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:.06em;font-weight:600;margin-bottom:4px}
.link-card h4{font-size:.98rem;font-weight:700;color:var(--text);margin-bottom:4px}
.link-card p{font-size:.85rem;color:var(--text-secondary);margin:0}
.faq details{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:14px 20px;margin-bottom:10px}
.faq summary{cursor:pointer;font-weight:600;color:var(--text);list-style:none}
.faq summary::-webkit-details-marker{display:none}
.faq summary::after{content:'+';float:right;color:var(--text-muted);font-weight:300;font-size:1.4rem;line-height:1}
.faq details[open] summary::after{content:'−'}
.faq details[open] summary{margin-bottom:10px;color:var(--accent)}
.faq details p{margin:10px 0 0;color:var(--text-secondary)}
.obp-footer{border-top:1px solid var(--border);margin-top:44px;padding-top:26px;color:var(--text-muted);font-size:.9rem}
.obp-footer__disclaimer{background:var(--surface);border-left:3px solid var(--accent);padding:14px 18px;border-radius:0 6px 6px 0;margin-bottom:20px;color:var(--text-secondary)}
.obp-footer__disclaimer strong{color:var(--text)}
footer.site-footer{padding:28px 0;border-top:1px solid var(--border);color:var(--text-muted);font-size:.85rem;text-align:center}
@media(max-width:720px){.hero h1{font-size:1.7rem}}</style>
</head>
