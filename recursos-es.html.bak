.hub-links{display:flex;flex-wrap:wrap;gap:0.5rem}
.hub-link{display:inline-flex;flex-direction:column;background:#21262d;border:1px solid var(--border);border-radius:6px;padding:0.5rem 1rem;font-size:0.85rem;color:var(--accent);text-decoration:none;transition:border-color 0.2s}
